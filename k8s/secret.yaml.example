# Copy to secret.yaml and fill with base64-encoded values. DO NOT commit secret.yaml.
# Create: kubectl create secret generic order-service-secrets -n order-processing \
#   --from-literal=GEMINI_API_KEY=your-key \
#   --from-literal=SLACK_WEBHOOK_URL=your-webhook-url
# Or apply this file after replacing the placeholders (then: kubectl apply -f secret.yaml).
---
apiVersion: v1
kind: Secret
metadata:
  name: order-service-secrets
  namespace: order-processing
  labels:
    app: order-service
type: Opaque
stringData:
  # Replace with your actual values (stringData accepts plain text; Kubernetes encodes them).
  GEMINI_API_KEY: "REPLACE_WITH_GEMINI_API_KEY"
  SLACK_WEBHOOK_URL: "REPLACE_WITH_SLACK_WEBHOOK_URL"
